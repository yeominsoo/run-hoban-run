APIKEY=replace-with-openai-api-key
OPENAPI=replace-with-openai-api-key
OPENAI_API=replace-with-openai-api-key
OPENAI_API_KEY=replace-with-openai-api-key

# 가위바위보(/rps) 실시간 매칭 서버 주소. 미설정 시 개발 중에는
# ws://<현재 호스트>:8787/rps 로 자동 접속을 시도한다.
# WAS 배포 후에는 wss://<확정 도메인>/rps 를 지정하고 빌드해야 한다.
# 자세한 내용은 ws-server/README.md 참고.
VITE_RPS_WS_URL=

# 라이어게임(/liar) 실시간 매칭 서버 주소. 미설정 시 개발 중에는
# ws://<현재 호스트>:8787/liar 로 자동 접속을 시도한다.
# rps와 같은 서버 프로세스가 서비스하므로 WAS 배포 후에는 같은 도메인의 /liar 경로를 지정한다.
# 자세한 내용은 ws-server/README.md 참고.
VITE_LIAR_WS_URL=

# 마피아게임(/mafia) 실시간 매칭 서버 주소. 미설정 시 개발 중에는
# ws://<현재 호스트>:8787/mafia 로 자동 접속을 시도한다.
# rps/liar와 같은 서버 프로세스가 서비스하므로 WAS 배포 후에는 같은 도메인의 /mafia 경로를 지정한다.
# 자세한 내용은 ws-server/README.md 참고.
VITE_MAFIA_WS_URL=

# 할리갈리(/halligalli) 실시간 매칭 서버 주소. 미설정 시 개발 중에는
# ws://<현재 호스트>:8787/halligalli 로 자동 접속을 시도한다.
# rps/liar/mafia와 같은 서버 프로세스가 서비스하므로 WAS 배포 후에는 같은 도메인의 /halligalli 경로를 지정한다.
# 자세한 내용은 ws-server/README.md 참고.
VITE_HALLIGALLI_WS_URL=

# 윷놀이(/yutnori) 실시간 매칭 서버 주소. 미설정 시 개발 중에는
# ws://<현재 호스트>:8787/yutnori 로 자동 접속을 시도한다.
# rps/liar/mafia/halligalli와 같은 서버 프로세스가 서비스하므로 WAS 배포 후에는 같은 도메인의 /yutnori 경로를 지정한다.
# 자세한 내용은 ws-server/README.md 참고.
VITE_YUTNORI_WS_URL=

# 전략윷놀이(/strategy-yutnori) 실시간 매칭 서버 주소. 미설정 시 개발 중에는
# ws://<현재 호스트>:8787/strategy-yutnori 로 자동 접속을 시도한다.
# rps/liar/mafia/halligalli/yutnori와 같은 서버 프로세스가 서비스하므로 WAS 배포 후에는 같은 도메인의 /strategy-yutnori 경로를 지정한다.
# 자세한 내용은 ws-server/README.md 참고.
VITE_STRATEGY_YUTNORI_WS_URL=

# 두더지 사냥(/mole-hunt) 실시간 매칭 서버 주소. 미설정 시 개발 중에는
# ws://<현재 호스트>:8787/mole-hunt 로 자동 접속을 시도한다.
# rps/liar/mafia/halligalli/yutnori/strategy-yutnori와 같은 서버 프로세스가 서비스하므로 WAS 배포 후에는 같은 도메인의 /mole-hunt 경로를 지정한다.
# 자세한 내용은 ws-server/README.md 참고.
VITE_MOLE_HUNT_WS_URL=
