FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY index.html ./
COPY assets ./assets
COPY docs ./docs
COPY eslint.config.js tsconfig.json vite.config.ts ./
COPY src ./src
COPY tests ./tests

CMD ["sh", "-c", "npm run typecheck && npm run lint && npm test && npm run build"]
