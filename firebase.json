{
  "hosting": {
    "site": "hoban-lakepark-ab19",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/race/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/team/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/race",
        "destination": "/race/index.html"
      },
      {
        "source": "/race/**",
        "destination": "/race/index.html"
      },
      {
        "source": "/team",
        "destination": "/team/index.html"
      },
      {
        "source": "/team/**",
        "destination": "/team/index.html"
      }
    ]
  }
}
