    "rewrites": [
      {
        "source": "/race",
        "destination": "/race/index.html"
      },
      {
        "source": "/race/**",
        "destination": "/race/index.html"
      },
      {
        "source": "/team",
        "destination": "/team/index.html"
      },
      {
        "source": "/team/**",
        "destination": "/team/index.html"
      },
      {
        "source": "/dice",
